---
// Native Astro port of src/SiteFooter.jsx. The static shell renders as HTML;
// only the genuinely interactive contact form is hydrated, via `client:visible`
// (React loads only when the form scrolls into view). This is the island model:
// one interactive widget instead of a whole-page React app.
import ContactFormIsland from './ContactFormIsland.jsx'

const { showContact = true } = Astro.props
---
{showContact && (
  <section id="contact" class="contact">
    <div class="contact__inner">
      <h2 class="contact__title reveal">Let&rsquo;s Get Started</h2>
      <p class="contact__sub reveal">
        Call <strong>808-518-4298</strong> or fill out the form below to learn more about our
        services and innovative agency approach.
      </p>
      <ContactFormIsland formName="footer" client:visible />
    </div>
  </section>
)}

<footer class="footer">
  <div class="footer__inner">
    <img src="/CC_Icon.png" alt="Covert Communication" class="footer__logo" />
    <div class="footer__social" aria-label="Social links">
      <a href="https://www.linkedin.com/company/covert-communication/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <img src="/icons/sm_linkdin.svg" alt="LinkedIn" />
      </a>
      <a href="https://facebook.com/covertcommunication" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <img src="/icons/sm_fb.svg" alt="Facebook" />
      </a>
      <a href="mailto:anna@covertcommunication.com" aria-label="Email">
        <img src="/icons/sm_email.svg" alt="Email" />
      </a>
    </div>
    <p class="footer__legal">
      Copyright 2026 Covert Communication LLC | All Rights Reserved |{' '}
      <a href="#">Privacy Policy</a> |{' '}
      <a href="#">Cookie Preferences</a> |{' '}
      <a href="#">Terms of Service</a> |{' '}
      <a href="#">Site Map</a> | 808-272-9952
    </p>
  </div>
</footer>
